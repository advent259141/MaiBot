{
  "manifest_version": 1,
  "name": "AstrBot Bridge",
  "version": "1.0.0",
  "description": "接收AstrBot推送的工具定义并注册为本地BaseTool代理，使MaiBot的LLM ToolExecutor能够调用AstrBot侧的工具",
  "author": {
    "name": "AstrBot",
    "url": "https://github.com/Soulter/AstrBot"
  },
  "license": "GPL-v3.0-or-later",
  "host_application": {
    "min_version": "0.10.0"
  },
  "keywords": ["astrbot", "tool", "bridge", "proxy"],
  "categories": ["Integration"],
  "plugin_info": {
    "is_built_in": true,
    "plugin_type": "tool_provider",
    "components": [
      {
        "type": "event_handler",
        "name": "astrbot_bridge_init",
        "description": "ON_START时注册WS自定义消息处理器，接收工具同步和工具调用结果"
      }
    ]
  }
}
